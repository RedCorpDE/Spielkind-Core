NODE_ENV=development
PORT=3000
# Local development only. On Render, use linked Postgres DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spielkind?sslmode=disable
DATABASE_SSL=false

REGIONDO_PUBLIC_KEY=
REGIONDO_PRIVATE_KEY=
REGIONDO_BASE_URL=https://api.regiondo.com/v1
REGIONDO_LANGUAGE=de-DE

# If Regiondo sends a signed webhook payload, put the shared secret here.
REGIONDO_WEBHOOK_SECRET=
WEBHOOK_BOOKINGS_PATH=/webhooks/regiondo/bookings
# In production, configure at least one auth method:
# - REGIONDO_WEBHOOK_SECRET
# - WEBHOOK_AUTH_HEADER_NAME + WEBHOOK_AUTH_HEADER_VALUE
WEBHOOK_AUTH_HEADER_NAME=x-webhook-token
WEBHOOK_AUTH_HEADER_VALUE=

# minute hour day month weekday; run once every day at 03:00 UTC
PRODUCT_SYNC_CRON=0 3 * * *

# Outbound: Retool webhook URLs for time-based booking notifications
# Set OUTBOUND_ENABLED=true to activate. Default: false (safe for new deployments).
OUTBOUND_ENABLED=false
RETOOL_WEBHOOK_CLIENT_MESSAGE=
RETOOL_WEBHOOK_CHECK_OUT=
# Text sent in check-out payloads as agentGeneratedGoodbye
CHECKOUT_GOODBYE_TEXT=Danke fuer euren Besuch! Wir freuen uns, euch bald wieder begruessen zu duerfen.
# How many minutes back to scan for missed events on startup (default: 60)
OUTBOUND_STARTUP_CATCHUP_MINUTES=60

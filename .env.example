# ── PostgreSQL (Render) ─────────────────────
# Connection-URL aus dem Render Dashboard kopieren
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require

# ── Regiondo API ────────────────────────────
REGIONDO_PUBLIC_KEY=
REGIONDO_PRIVATE_KEY=
REGIONDO_BASE_URL=https://api.regiondo.com/v1/
REGIONDO_LANGUAGE=de-DE

REGIONDO_THROTTLE_MS=200

REGIONDO_CONCURRENCY_PRODUCTS=3
REGIONDO_CONCURRENCY_VARIATIONS=3
REGIONDO_PAGE_LIMIT=50
REGIONDO_MAX_PAGES=100

# ── App Settings ────────────────────────────
NODE_ENV=development
SYNC_INTERVAL_MINUTES=5

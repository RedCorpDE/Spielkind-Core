NODE_ENV=development
PORT=3000
# Local development only. On Render, use linked Postgres DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spielkind?sslmode=disable
DATABASE_SSL=false

REGIONDO_PUBLIC_KEY=
REGIONDO_PRIVATE_KEY=
REGIONDO_BASE_URL=https://api.regiondo.com/v1
REGIONDO_LANGUAGE=de-DE

# If Regiondo sends a signed webhook payload, put the shared secret here.
REGIONDO_WEBHOOK_SECRET=
WEBHOOK_BOOKINGS_PATH=/webhooks/regiondo/bookings
WEBHOOK_AUTH_HEADER_NAME=x-webhook-token
WEBHOOK_AUTH_HEADER_VALUE=

# minute hour day month weekday; run once every day at 03:00 UTC
PRODUCT_SYNC_CRON=0 3 * * *

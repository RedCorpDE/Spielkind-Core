# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local:
# Render: Automatically provided via DATABASE_URL from linked database
DATABASE_URL=
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Embedded Scheduler
# -----------------------------------------------------------------------------
ENABLE_EMBEDDED_SCHEDULER=true
SCHEDULER_TIMEZONE=Europe/Berlin
CRON_SECRET=replace-with-a-long-random-secret

# Webhook processing cron
REGIONDO_WEBHOOK_CRON=*/1 * * * *
# Weekly Regiondo catalog sync cron (Monday 03:00 Europe/Berlin)
REGIONDO_CATALOG_SYNC_CRON=0 3 * * 1
# Reminder dispatch cron
REMINDER_DISPATCH_CRON=*/5 * * * *

# -----------------------------------------------------------------------------
# Regiondo API
# -----------------------------------------------------------------------------
REGIONDO_BASE_URL=
REGIONDO_PUBLIC_KEY=
REGIONDO_SECRET_KEY=
REGIONDO_PRODUCT_SUPPLIER_ID=
REGIONDO_LANGUAGE=de-DE

# Request settings
REGIONDO_REQUEST_TIMEOUT_MS=10000
REGIONDO_REQUEST_MAX_RETRIES=2
REGIONDO_REQUEST_RETRY_BASE_DELAY_MS=500

# -----------------------------------------------------------------------------
# Regiondo Webhook
# -----------------------------------------------------------------------------
# Optional shared secret if Regiondo signs webhook payloads with HMAC
REGIONDO_WEBHOOK_SECRET=

# Alternative: static auth header for webhook endpoint
# WEBHOOK_AUTH_HEADER_NAME=x-webhook-token
# WEBHOOK_AUTH_HEADER_VALUE=

# Webhook inbox settings
REGIONDO_WEBHOOK_MAX_ATTEMPTS=8
REGIONDO_WEBHOOK_BATCH_SIZE=25
REGIONDO_WEBHOOK_WORKER_INTERVAL_MS=10000
REGIONDO_WEBHOOK_WORKER_BATCH_SIZE=25
WEBHOOK_BODY_LIMIT_BYTES=262144

# -----------------------------------------------------------------------------
# Admin Dashboard
# -----------------------------------------------------------------------------
DASHBOARD_ALLOWED_ORIGIN=http://localhost:5173

# Admin access tokens (JWT)
ADMIN_ACCESS_TOKEN_SECRET=
ADMIN_ACCESS_TOKEN_TTL_MINUTES=15

# Admin sessions (refresh tokens)
ADMIN_SESSION_TTL_DAYS=
ADMIN_REFRESH_COOKIE_NAME=

# Admin password requirements
ADMIN_PASSWORD_MIN_LENGTH=12

# -----------------------------------------------------------------------------
# Reminder Provider
# -----------------------------------------------------------------------------
# Core sends structured reminder events to this webhook endpoint.
REMINDER_PROVIDER_WEBHOOK_URL=
REMINDER_PROVIDER_SECRET=
